use shared_components::ascii;

pub type CardData = uint<8>;
pub type CardOffset = uint<11>;

pub enum ParserEvent {
    None,
    ReadRam{addr: CardOffset},
    WriteRam{addr: CardOffset, value: CardData},
    ReadRom{addr: CardOffset},
    WriteRom{addr: CardOffset, value: CardData},
    SetClassifyDelay{cycles: uint<7>},
    SetFtStreaming{enabled: bool},
    ParseErr,
}

pub enum EchoMsg {
    None,
    Byte{byte: uint<8>},
    CrLf,
}

pub enum ParserState {
    Idle,
    ReadAddr{digits: uint<2>, value: CardOffset, rom: bool},
    NeedReadLineEnd{addr: CardOffset, rom: bool},
    WriteAddr{digits: uint<2>, value: CardOffset, rom: bool},
    WriteEq{addr: CardOffset, rom: bool},
    WriteDataHi{addr: CardOffset, rom: bool},
    WriteDataLo{addr: CardOffset, hi: uint<4>, rom: bool},
    NeedWriteLineEnd{addr: CardOffset, value: CardData, rom: bool},
    TimingHi,
    TimingLo{tens: uint<4>},
    NeedTimingLineEnd{cycles: uint<7>},
    FtEnable,
    NeedFtLineEnd{enabled: bool},
    Error,
}

pub struct ParserStepOut {
    state: ParserState,
    event: ParserEvent,
    echo: EchoMsg,
}

pub fn init_parser() -> ParserState {
    ParserState::Idle()
}


fn parser_out(next_state: ParserState, event: ParserEvent, echo: EchoMsg) -> ParserStepOut {
    ParserStepOut$(state: next_state, event: event, echo: echo)
}

fn parser_error(state: ParserState, rx_byte: uint<8>) -> ParserStepOut {
    if rx_byte.is_line_end() {
        parser_out(ParserState::Idle(), ParserEvent::ParseErr(), EchoMsg::CrLf())
    } else {
        parser_out(ParserState::Error(), ParserEvent::None(), EchoMsg::None())
    }
}

fn addr_accum(value: CardOffset, nibble: uint<4>) -> CardOffset {
    trunc((value << 4) | zext(nibble))
}

fn read_event(addr: CardOffset, rom: bool) -> ParserEvent {
    if rom {
        ParserEvent::ReadRom(addr)
    } else {
        ParserEvent::ReadRam(addr)
    }
}

fn write_event(addr: CardOffset, value: CardData, rom: bool) -> ParserEvent {
    if rom {
        ParserEvent::WriteRom(addr, value)
    } else {
        ParserEvent::WriteRam(addr, value)
    }
}

pub fn parser_step(
    state: ParserState,
    rx_valid: bool,
    rx_parity_error: bool,
    rx_byte: uint<8>,
) -> ParserStepOut {
    if !rx_valid {
        ParserStepOut$(state: state, event: ParserEvent::None(), echo: EchoMsg::None())
    } else if rx_parity_error {
        parser_error(state, rx_byte)
    } else {
        let decoded = rx_byte.decode_hex();
        let nibble_ok = decoded.valid;
        let nibble = decoded.value;
        match state {
            ParserState::Idle => {
                if rx_byte.is_line_end() {
                    parser_out(ParserState::Idle(), ParserEvent::None(), EchoMsg::None())
                } else if rx_byte == b'r' {
                    parser_out(ParserState::ReadAddr(0, 0, false), ParserEvent::None(), EchoMsg::Byte(rx_byte))
                } else if rx_byte == b'R' {
                    parser_out(ParserState::ReadAddr(0, 0, true), ParserEvent::None(), EchoMsg::Byte(rx_byte))
                } else if rx_byte == b'w' {
                    parser_out(ParserState::WriteAddr(0, 0, false), ParserEvent::None(), EchoMsg::Byte(rx_byte))
                } else if rx_byte == b'W' {
                    parser_out(ParserState::WriteAddr(0, 0, true), ParserEvent::None(), EchoMsg::Byte(rx_byte))
                } else if rx_byte.to_upper() == b'T' {
                    parser_out(ParserState::TimingHi(), ParserEvent::None(), EchoMsg::Byte(rx_byte))
                } else if rx_byte.to_upper() == b'F' {
                    parser_out(ParserState::FtEnable(), ParserEvent::None(), EchoMsg::Byte(rx_byte))
                } else {
                    parser_error(state, rx_byte)
                }
            },
            ParserState::ReadAddr$(digits, value, rom) => {
                if !nibble_ok || (digits == 0 && nibble > 7) {
                    parser_error(state, rx_byte)
                } else {
                    let next_digits = digits +. 1;
                    let next_value = addr_accum(value, nibble);
                    if next_digits == 3 {
                        parser_out(
                            ParserState::NeedReadLineEnd(next_value, rom),
                            ParserEvent::None(),
                            EchoMsg::Byte(rx_byte),
                        )
                    } else {
                        parser_out(
                            ParserState::ReadAddr(next_digits, next_value, rom),
                            ParserEvent::None(),
                            EchoMsg::Byte(rx_byte),
                        )
                    }
                }
            },
            ParserState::NeedReadLineEnd$(addr, rom) => {
                if rx_byte.is_line_end() {
                    parser_out(ParserState::Idle(), read_event(addr, rom), EchoMsg::CrLf())
                } else {
                    parser_error(state, rx_byte)
                }
            },
            ParserState::WriteAddr$(digits, value, rom) => {
                if !nibble_ok || (digits == 0 && nibble > 7) {
                    parser_error(state, rx_byte)
                } else {
                    let next_digits = digits +. 1;
                    let next_value = addr_accum(value, nibble);
                    if next_digits == 3 {
                        parser_out(
                            ParserState::WriteEq(next_value, rom),
                            ParserEvent::None(),
                            EchoMsg::Byte(rx_byte),
                        )
                    } else {
                        parser_out(
                            ParserState::WriteAddr(next_digits, next_value, rom),
                            ParserEvent::None(),
                            EchoMsg::Byte(rx_byte),
                        )
                    }
                }
            },
            ParserState::WriteEq$(addr, rom) => {
                if rx_byte == b'=' {
                    parser_out(ParserState::WriteDataHi(addr, rom), ParserEvent::None(), EchoMsg::Byte(rx_byte))
                } else {
                    parser_error(state, rx_byte)
                }
            },
            ParserState::WriteDataHi$(addr, rom) => {
                if nibble_ok {
                    parser_out(ParserState::WriteDataLo(addr, nibble, rom), ParserEvent::None(), EchoMsg::Byte(rx_byte))
                } else {
                    parser_error(state, rx_byte)
                }
            },
            ParserState::WriteDataLo$(addr, hi, rom) => {
                if nibble_ok {
                    let value: CardData = (zext(hi) << 4) | zext(nibble);
                    parser_out(
                        ParserState::NeedWriteLineEnd(addr, value, rom),
                        ParserEvent::None(),
                        EchoMsg::Byte(rx_byte),
                    )
                } else {
                    parser_error(state, rx_byte)
                }
            },
            ParserState::NeedWriteLineEnd$(addr, value, rom) => {
                if rx_byte.is_line_end() {
                    parser_out(ParserState::Idle(), write_event(addr, value, rom), EchoMsg::CrLf())
                } else {
                    parser_error(state, rx_byte)
                }
            },
            ParserState::TimingHi => {
                let digit = rx_byte.decode_digit();
                if digit.valid {
                    parser_out(ParserState::TimingLo(digit.value), ParserEvent::None(), EchoMsg::Byte(rx_byte))
                } else {
                    parser_error(state, rx_byte)
                }
            },
            ParserState::TimingLo$(tens) => {
                let digit = rx_byte.decode_digit();
                if digit.valid {
                    let tens_u8: uint<8> = zext(tens);
                    let digit_u8: uint<8> = zext(digit.value);
                    let ten_u8: uint<8> = 10;
                    let tens_times_ten: uint<8> = trunc(tens_u8 * ten_u8);
                    let cycles_u8: uint<8> = tens_times_ten +. digit_u8;
                    let cycles: uint<7> = trunc(cycles_u8);
                    parser_out(
                        ParserState::NeedTimingLineEnd(cycles),
                        ParserEvent::None(),
                        EchoMsg::Byte(rx_byte),
                    )
                } else {
                    parser_error(state, rx_byte)
                }
            },
            ParserState::NeedTimingLineEnd$(cycles) => {
                if rx_byte.is_line_end() {
                    parser_out(ParserState::Idle(), ParserEvent::SetClassifyDelay(cycles), EchoMsg::CrLf())
                } else {
                    parser_error(state, rx_byte)
                }
            },
            ParserState::FtEnable => {
                if rx_byte == b'0' {
                    parser_out(ParserState::NeedFtLineEnd(false), ParserEvent::None(), EchoMsg::Byte(rx_byte))
                } else if rx_byte == b'1' {
                    parser_out(ParserState::NeedFtLineEnd(true), ParserEvent::None(), EchoMsg::Byte(rx_byte))
                } else {
                    parser_error(state, rx_byte)
                }
            },
            ParserState::NeedFtLineEnd$(enabled) => {
                if rx_byte.is_line_end() {
                    parser_out(ParserState::Idle(), ParserEvent::SetFtStreaming(enabled), EchoMsg::CrLf())
                } else {
                    parser_error(state, rx_byte)
                }
            },
            ParserState::Error => {
                if rx_byte.is_line_end() {
                    parser_out(ParserState::Idle(), ParserEvent::ParseErr(), EchoMsg::CrLf())
                } else {
                    parser_out(ParserState::Error(), ParserEvent::None(), EchoMsg::None())
                }
            },
        }
    }
}
