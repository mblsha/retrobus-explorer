10 ' PC-E500 FPGA ASCII MEMORY DUMPER
20 ' WRITES ASCII TO A SINGLE FPGA "PRINT CHAR" ADDRESS.
30 ' OUTPUT FORMAT:
40 '   BEGIN C0000 FFFFF
50 '   C0000: XX XX XX XX XX XX XX XX XX XX XX XX XX XX XX XX
60 '   C0010: ...
70 '   END
80 '
90 ' DEFAULT RANGE: MAIN ROM ONLY.
100 ' YOU CAN PRESS ENTER TO USE DEFAULTS OR TYPE HEX VALUES.
110 '
120 FP=&H1FFF1
130 DST=&HC0000
140 DLN=&H40000
150 BPL=16
160 CLS
170 PRINT "FPGA ASCII DUMPER"
180 PRINT "PORT=";HEX$(FP)
190 PRINT "DEFAULT START=";HEX$(DST)
200 PRINT "DEFAULT LEN=";HEX$(DLN)
210 INPUT "START HEX";S$
220 IF S$="" THEN ST=DST ELSE ST=VAL("&H"+S$)
230 INPUT "LEN HEX";L$
240 IF L$="" THEN LE=DLN ELSE LE=VAL("&H"+L$)
250 IF LE<1 THEN PRINT "BAD LEN":END
260 EN=ST+LE-1
270 PRINT "START=";HEX$(ST);" END=";HEX$(EN);" LEN=";HEX$(LE);" BPL=";BPL
280 MSG$="BEGIN ":GOSUB 9000
290 V=ST:GOSUB 9200
300 POKE FP,32
310 V=EN:GOSUB 9200
320 GOSUB 9100
330 FOR A=ST TO EN STEP BPL
340   L=EN-A+1
350   IF L>BPL THEN L=BPL
360   V=A:GOSUB 9200
370   MSG$=": ":GOSUB 9000
380   FOR I=0 TO L-1
390     V=PEEK(A+I):GOSUB 9300
400     IF I<L-1 THEN POKE FP,32
410   NEXT I
420   GOSUB 9100
430 NEXT A
440 MSG$="END":GOSUB 9000
450 GOSUB 9100
460 PRINT "DONE"
470 END
9000 FOR J=1 TO LEN(MSG$)
9010   POKE FP,ASC(MID$(MSG$,J,1))
9020 NEXT J
9030 RETURN
9100 POKE FP,13
9110 POKE FP,10
9120 RETURN
9200 H$=HEX$(V)
9210 FOR J=1 TO 5-LEN(H$)
9220   POKE FP,48
9230 NEXT J
9240 MSG$=H$:GOSUB 9000
9250 RETURN
9300 H$=HEX$(V)
9310 IF LEN(H$)=1 THEN H$="0"+H$
9320 MSG$=H$:GOSUB 9000
9330 RETURN
