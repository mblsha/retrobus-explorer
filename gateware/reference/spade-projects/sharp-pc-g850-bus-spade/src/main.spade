fn help_msg_byte(idx: uint<16>) -> (bool, uint<8>) {
    if idx < 7 {
        help_line0(idx)
    } else if idx < 23 {
        help_line1(trunc(idx - 7))
    } else if idx < 53 {
        help_line2(trunc(idx - 23))
    } else if idx < 84 {
        help_line3(trunc(idx - 53))
    } else if idx < 117 {
        help_line4(trunc(idx - 84))
    } else if idx < 158 {
        help_line5(trunc(idx - 117))
    } else if idx < 195 {
        help_line6(trunc(idx - 158))
    } else if idx < 226 {
        help_line7(trunc(idx - 195))
    } else if idx < 259 {
        help_line8(trunc(idx - 226))
    } else if idx < 290 {
        help_line9(trunc(idx - 259))
    } else if idx < 355 {
        help_line10(trunc(idx - 290))
    } else if idx < 393 {
        help_line11(trunc(idx - 355))
    } else {
        (false, 0)
    }
}

