enum ConsoleMsg {
    None,
    Ok,
    Err,
    Help,
    Status,
    PinMap,
}

fn console_msg_is_none(msg: ConsoleMsg) -> bool {
    match msg {
        ConsoleMsg::None => true,
        _ => false,
    }
}

fn mode_char(mode: SaleaeState) -> uint<8> {
    match mode {
        SaleaeState::DataSignals => ascii_upper_d(),
        SaleaeState::SyncSignals => ascii_upper_s(),
        SaleaeState::EdgeSignals => ascii_upper_e(),
        SaleaeState::RawSignals => ascii_upper_r(),
        SaleaeState::Counter => ascii_upper_c(),
    }
}

fn mode_char_lower(mode: SaleaeState) -> uint<8> {
    match mode {
        SaleaeState::DataSignals => 0x64,
        SaleaeState::SyncSignals => 0x73,
        SaleaeState::EdgeSignals => 0x65,
        SaleaeState::RawSignals => 0x72,
        SaleaeState::Counter => 0x63,
    }
}

fn bool_char(v: bool) -> uint<8> {
    if v {
        trunc(ascii_zero() + 1)
    } else {
        ascii_zero()
    }
}

fn wait_char(wait_enabled: uint<8>) -> uint<8> {
    let d = if wait_enabled > 9 { 9 } else { wait_enabled };
    trunc(ascii_zero() + d)
}

fn console_msg_byte(
    msg: ConsoleMsg,
    idx: uint<16>,
    wait_enabled: uint<8>,
    saleae_state: SaleaeState,
    ft_enabled: bool,
    ft_remote_allowed: bool,
    ft_armed: bool,
) -> (bool, uint<8>) {
    let slash: uint<8> = 0x2f;
    match msg {
        ConsoleMsg::None => (false, 0),
        ConsoleMsg::Ok => {
            if idx == 0 {
                (true, 0x6f)
            } else if idx == 1 {
                (true, 0x6b)
            } else if idx == 2 {
                (true, ascii_cr())
            } else if idx == 3 {
                (true, ascii_lf())
            } else {
                (false, 0)
            }
        },
        ConsoleMsg::Err => {
            if idx == 0 {
                (true, 0x65)
            } else if idx == 1 {
                (true, 0x72)
            } else if idx == 2 {
                (true, 0x72)
            } else if idx == 3 {
                (true, ascii_cr())
            } else if idx == 4 {
                (true, ascii_lf())
            } else {
                (false, 0)
            }
        },
        ConsoleMsg::Help => help_msg_byte(idx),
        ConsoleMsg::PinMap => saleae_map_msg_byte(idx, saleae_state),
        ConsoleMsg::Status => {
            if idx == 0 {
                (true, 0x73)
            } else if idx == 1 {
                (true, 0x74)
            } else if idx == 2 {
                (true, 0x61)
            } else if idx == 3 {
                (true, 0x74)
            } else if idx == 4 {
                (true, ascii_space())
            } else if idx == 5 {
                (true, 0x66)
            } else if idx == 6 {
                (true, ascii_eq())
            } else if idx == 7 {
                (true, bool_char(ft_enabled))
            } else if idx == 8 {
                (true, ascii_space())
            } else if idx == 9 {
                (true, 0x72)
            } else if idx == 10 {
                (true, ascii_eq())
            } else if idx == 11 {
                (true, bool_char(ft_remote_allowed))
            } else if idx == 12 {
                (true, ascii_space())
            } else if idx == 13 {
                (true, 0x61)
            } else if idx == 14 {
                (true, ascii_eq())
            } else if idx == 15 {
                (true, bool_char(ft_armed))
            } else if idx == 16 {
                (true, ascii_space())
            } else if idx == 17 {
                (true, 0x77)
            } else if idx == 18 {
                (true, ascii_eq())
            } else if idx == 19 {
                (true, wait_char(wait_enabled))
            } else if idx == 20 {
                (true, ascii_space())
            } else if idx == 21 {
                (true, 0x6d)
            } else if idx == 22 {
                (true, ascii_eq())
            } else if idx == 23 {
                (true, mode_char_lower(saleae_state))
            } else if idx == 24 {
                (true, ascii_cr())
            } else if idx == 25 {
                (true, ascii_lf())
            } else {
                (false, 0)
            }
        },
    }
}

fn help_line0(idx: uint<16>) -> (bool, uint<8>) {
    let text: [uint<8>; 7] = [
        0x48, 0x65, 0x6c, 0x70, 0x3a, 0x0d, 0x0a,
    ];
    if idx < 7 {
        (true, text[trunc(idx)])
    } else {
        (false, 0)
    }
}

