    let line3 = text_byte_at(idx, 118, [
        0x73, 0x3a, 0x20, 0x64, 0x30, 0x3d, 0x77, 0x72, 0x5f, 0x72, 0x69, 0x73, 0x65, 0x20,
        0x64, 0x31, 0x3d, 0x72, 0x64, 0x5f, 0x72, 0x69, 0x73, 0x65, 0x20, 0x64, 0x32, 0x3d,
        0x6d, 0x72, 0x65, 0x71, 0x5f, 0x66, 0x61, 0x6c, 0x6c, 0x20, 0x64, 0x33, 0x3d, 0x6d,
        0x31, 0x5f, 0x73, 0x79, 0x6e, 0x63, 0x20, 0x64, 0x34, 0x3d, 0x77, 0x72, 0x5f, 0x73,
