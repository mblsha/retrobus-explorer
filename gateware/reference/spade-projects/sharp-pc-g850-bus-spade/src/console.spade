        0x69, 0x74, 0x20, 0x6c, 0x65, 0x76, 0x65, 0x6c, 0x20, 0x28, 0x30, 0x3d, 0x6d, 0x69,
        0x6e, 0x20, 0x77, 0x61, 0x69, 0x74, 0x29, 0x0d, 0x0a,
