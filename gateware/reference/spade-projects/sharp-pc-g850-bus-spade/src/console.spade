use shared_components::ascii::ascii_cr;
use shared_components::ascii::ascii_lf;
use shared_components::ascii::ascii_zero;
use shared_components::bus_debug::SaleaeState;
use shared_components::message_stream::ByteMsgStreamOut;
use shared_components::message_stream::ByteMsgStreamState;
use shared_components::message_stream::TxReq8;
use shared_components::message_stream::byte_msg_stream_step;
use shared_components::message_stream::tx_req_arbiter;
use shared_components::message_stream::tx_req_none;

pub enum ConsoleMsg {
    None,
    Ok,
    Err,
    Help,
    Status,
    PinMap,
}

pub struct ConsoleMsgContext {
    wait_enabled: uint<8>,
    saleae_state: SaleaeState,
    ft_enabled: bool,
    ft_remote_allowed: bool,
    ft_armed: bool,
}

pub fn console_msg_is_none(msg: ConsoleMsg) -> bool {
    match msg {
        ConsoleMsg::None => true,
        _ => false,
    }
}

fn bool_char(v: bool) -> uint<8> {
    if v {
        trunc(ascii_zero() + 1)
    } else {
        ascii_zero()
    }
}

fn wait_char(wait_enabled: uint<8>) -> uint<8> {
    let d = if wait_enabled > 9 { 9 } else { wait_enabled };
    trunc(ascii_zero() + d)
}

fn mode_char_lower(mode: SaleaeState) -> uint<8> {
    match mode {
        SaleaeState::DataSignals => 0x64,
        SaleaeState::SyncSignals => 0x73,
        SaleaeState::EdgeSignals => 0x65,
        SaleaeState::RawSignals => 0x72,
        SaleaeState::Counter => 0x63,
    }
}

fn text_byte<#uint N>(text: [uint<8>; N], idx: uint<16>) -> TxReq8 {
    if idx < N {
        TxReq8$(valid: true, byte: text[trunc(idx)])
    } else {
        tx_req_none()
    }
}

fn text_byte_at<#uint N>(idx: uint<16>, start: uint<16>, text: [uint<8>; N]) -> TxReq8 {
    let end: uint<16> = trunc(start + N);
    if idx >= start && idx < end {
        TxReq8$(valid: true, byte: text[trunc(idx - start)])
    } else {
        tx_req_none()
    }
}

fn literal_byte_at(idx: uint<16>, target: uint<16>, byte: uint<8>) -> TxReq8 {
    if idx == target {
        TxReq8$(valid: true, byte: byte)
    } else {
        tx_req_none()
    }
}

fn first_valid_byte(highest: TxReq8, high: TxReq8, low: TxReq8) -> TxReq8 {
    tx_req_arbiter(highest, high, low)
}

fn status_msg_byte(idx: uint<16>, ctx: ConsoleMsgContext) -> TxReq8 {
    first_valid_byte(
        text_byte_at(idx, 0, [0x73, 0x74, 0x61, 0x74, 0x20, 0x66, 0x3d]),
        literal_byte_at(idx, 7, bool_char(ctx.ft_enabled)),
        first_valid_byte(
            text_byte_at(idx, 8, [0x20, 0x72, 0x3d]),
            literal_byte_at(idx, 11, bool_char(ctx.ft_remote_allowed)),
            first_valid_byte(
                text_byte_at(idx, 12, [0x20, 0x61, 0x3d]),
                literal_byte_at(idx, 15, bool_char(ctx.ft_armed)),
                first_valid_byte(
                    text_byte_at(idx, 16, [0x20, 0x77, 0x3d]),
                    literal_byte_at(idx, 19, wait_char(ctx.wait_enabled)),
                    first_valid_byte(
                        text_byte_at(idx, 20, [0x20, 0x6d, 0x3d]),
                        literal_byte_at(idx, 23, mode_char_lower(ctx.saleae_state)),
                        text_byte_at(idx, 24, [ascii_cr(), ascii_lf()]),
                    ),
                ),
            ),
        ),
    )
}

