    let line4 = text_byte_at(idx, 216, [
        0x65, 0x3a, 0x20, 0x64, 0x30, 0x3d, 0x77, 0x72, 0x5f, 0x72, 0x69, 0x73, 0x65, 0x20,
        0x64, 0x31, 0x3d, 0x72, 0x64, 0x5f, 0x72, 0x69, 0x73, 0x65, 0x20, 0x64, 0x32, 0x3d,
