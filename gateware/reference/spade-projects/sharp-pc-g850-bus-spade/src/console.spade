fn saleae_map_msg_byte(idx: uint<16>, saleae_state: SaleaeState) -> TxReq8 {
    let line0 = first_valid_byte(
        text_byte_at(idx, 0, [
            0x6d, 0x61, 0x70, 0x20, 0x6d, 0x6f, 0x64, 0x65, 0x3d,
        ]),
        literal_byte_at(idx, 9, mode_char_lower(saleae_state)),
        text_byte_at(idx, 10, [0x0d, 0x0a]),
