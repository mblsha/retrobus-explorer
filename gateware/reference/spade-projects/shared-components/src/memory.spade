#[no_mangle(all)]
extern entity async_fifo_u8x8_v(
    wclk: clock,
    wrst: bool,
    din: uint<8>,
    wput: bool,
    full: inv &bool,
    rclk: clock,
    rrst: bool,
    dout: inv &uint<8>,
    rget: bool,
    empty: inv &bool,
);

#[no_mangle(all)]
extern entity async_fifo_u8x4_v(
    wclk: clock,
    wrst: bool,
    din: uint<8>,
    wput: bool,
    full: inv &bool,
    rclk: clock,
    rrst: bool,
    dout: inv &uint<8>,
    rget: bool,
    empty: inv &bool,
);

#[no_mangle(all)]
extern entity async_fifo_u16x4_v(
    wclk: clock,
    wrst: bool,
    din: uint<16>,
    wput: bool,
