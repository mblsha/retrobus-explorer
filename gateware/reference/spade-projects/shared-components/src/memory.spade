    clk: clock,
    rst: bool,
    din: uint<32>,
    wput: bool,
    rget: bool,
) -> FifoOut<uint<32>> {
    let (fifo, fifo_w): (FifoOutPort<uint<32>>, inv FifoOutPort<uint<32>>) = port;
