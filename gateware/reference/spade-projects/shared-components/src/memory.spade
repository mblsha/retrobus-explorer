pub entity fifo_out_tap<T>(
    out: FifoOut<T>,
    full: inv &bool,
    empty: inv &bool,
    dout: inv &T,
) {
    set full = &out.full;
    set empty = &out.empty;
    set dout = &out.dout;
}

pub entity async_fifo_u8x4_tap(
    wclk: clock,
    wrst: bool,
    din: uint<8>,
    wput: bool,
    rclk: clock,
    rrst: bool,
    rget: bool,
    full: inv &bool,
    empty: inv &bool,
    dout: inv &uint<8>,
) {
    let out = inst async_fifo_u8x4(wclk, wrst, din, wput, rclk, rrst, rget);
    inst fifo_out_tap(out, full, empty, dout);
}

pub entity async_fifo_u16x4_tap(
    wclk: clock,
    wrst: bool,
    din: uint<16>,
    wput: bool,
    rclk: clock,
    rrst: bool,
    rget: bool,
    full: inv &bool,
    empty: inv &bool,
    dout: inv &uint<16>,
) {
    let out = inst async_fifo_u16x4(wclk, wrst, din, wput, rclk, rrst, rget);
    inst fifo_out_tap(out, full, empty, dout);
}

pub entity fifo_u32x32768_tap(
    clk: clock,
    rst: bool,
    din: uint<32>,
    wput: bool,
    rget: bool,
    full: inv &bool,
    empty: inv &bool,
    dout: inv &uint<32>,
) {
    let out = inst fifo_u32x32768(clk, rst, din, wput, rget);
    inst fifo_out_tap(out, full, empty, dout);
}
