use shared_components::ascii::DigitDecode;
use shared_components::ascii::decode_digit_max;
use shared_components::ascii::to_upper;
use shared_components::message_stream::ByteMsgStreamOut;
use shared_components::message_stream::ByteMsgStreamState;
use shared_components::message_stream::TxReq8;
use shared_components::message_stream::byte_msg_stream_step_with;

pub enum Mode {
    ClockTester,
    Echo,
}

pub enum CmdParseState {
    Idle,
    Bang,
    Freq,
}

pub enum MsgKind {
    None,
    Ready,
    Help,
    Status,
    Ok,
    ErrCmd,
    ErrFreq,
}

pub fn mode_char(mode: Mode) -> uint<8> {
    match mode {
        Mode::ClockTester => b'C',
        Mode::Echo => b'E',
    }
}

pub fn digit_char(value: uint<4>) -> uint<8> {
    let v: uint<8> = zext(value);
    trunc(v + b'0')
}

pub struct MsgTemplate {
    len: uint<8>,
    bytes: [uint<8>; 64],
}

pub struct RxByteDecode {
    byte: uint<8>,
    upper: uint<8>,
    digit: DigitDecode,
}

fn default_rx_byte_decode() -> RxByteDecode {
    RxByteDecode$(
        byte: 0,
        upper: 0,
        digit: DigitDecode$(valid: false, value: 0),
    )
}

entity decode_rx_byte(
    clk: clock,
    rx_valid: bool,
    rx_parity_error: bool,
    rx_byte: uint<8>,
) -> Option<RxByteDecode> {
    let max_freq_code: uint<4> = 5;
    let maybe_rx_byte = if rx_valid && !rx_parity_error { Some(rx_byte) } else { None };

    maybe_rx_byte.inst(_) pmap(clk, pipeline(0) |clk, byte| {
        let _ = clk;
        RxByteDecode$(
            byte: byte,
            upper: to_upper(byte),
            digit: decode_digit_max(byte, max_freq_code),
        )
    })
}

pub fn pad_message<#uint N>(message: [uint<8>; N]) -> [uint<8>; 64] {
    std::conv::concat_arrays(message, [0; 64 - N])
}

pub fn msg_template_bytes<#uint N>(message: [uint<8>; N]) -> MsgTemplate {
    let len: uint<8> = N;
    MsgTemplate$(len: len, bytes: pad_message(message))
}

fn mode_freq_suffix(mode: uint<8>, freq: uint<8>) -> [uint<8>; 10] {
    [b' ', b'M', b'=', mode, b' ', b'F', b'=', freq, b'\r', b'\n']
}

pub fn msg_template(msg: MsgKind, mode: Mode, freq_code: uint<4>) -> MsgTemplate {
    let m = mode_char(mode);
    let f = digit_char(freq_code);

    match msg {
        MsgKind::None => MsgTemplate$(len: 0, bytes: [0; 64]),
        MsgKind::Ready => msg_template_bytes(std::conv::concat_arrays(b"RBX READY", mode_freq_suffix(m, f))),
        MsgKind::Help => msg_template_bytes(b"RBX HELP !H !S !C !E !F0-5 M:CLOCK E:ECHO\r\n"),
        MsgKind::Status => msg_template_bytes(std::conv::concat_arrays(b"RBX STATUS", mode_freq_suffix(m, f))),
        MsgKind::Ok => msg_template_bytes(std::conv::concat_arrays(b"RBX OK", mode_freq_suffix(m, f))),
        MsgKind::ErrCmd => msg_template_bytes(b"RBX ERR CMD\r\n"),
        MsgKind::ErrFreq => msg_template_bytes(b"RBX ERR FREQ\r\n"),
    }
}

pub fn msg_byte(msg: MsgKind, idx: uint<8>, mode: Mode, freq_code: uint<4>) -> TxReq8 {
    let msg_tpl = msg_template(msg, mode, freq_code);
    if idx < msg_tpl.len {
        TxReq8$(valid: true, byte: msg_tpl.bytes[trunc(idx)])
    } else {
        TxReq8$(valid: false, byte: 0)
    }
}

pub fn clock_from_code(freq_code: uint<4>, clk_div: uint<10>, clk200: bool, clk400: bool) -> bool {
    let bits = clk_div.to_bits();
    let sources: [bool; 6] = [
        bits[4],
        bits[3],
        bits[2],
        bits[1],
        clk200,
        clk400,
    ];
    let idx_u4: uint<4> = if freq_code > 5 { 0 } else { freq_code };
    let idx: uint<3> = trunc(idx_u4);
    sources[idx]
}

pub fn is_echo_mode(mode: Mode) -> bool {
    match mode {
        Mode::Echo => true,
        _ => false,
    }
}

pub fn cmd_state_is_idle(state: CmdParseState) -> bool {
    match state {
        CmdParseState::Idle => true,
        _ => false,
    }
}

pub fn next_cmd_state(
    state: CmdParseState,
    rx_ok: bool,
    rx_byte: uint<8>,
    rx_upper: uint<8>,
) -> CmdParseState {
    if !rx_ok {
        state
    } else {
        match state {
            CmdParseState::Idle => {
                if rx_byte == b'!' {
                    CmdParseState::Bang()
                } else {
                    CmdParseState::Idle()
                }
            },
            CmdParseState::Bang => {
                if rx_upper == b'F' {
                    CmdParseState::Freq()
                } else {
                    CmdParseState::Idle()
                }
            },
            CmdParseState::Freq => CmdParseState::Idle(),
        }
    }
}

pub struct CmdDecode {
    msg: MsgKind,
    msg_valid: bool,
    mode_write: bool,
    mode_value: Mode,
    freq_write: bool,
    freq_value: uint<4>,
}

pub fn cmd_decode_base(
    msg: MsgKind,
    msg_valid: bool,
    mode_write: bool,
    mode_value: Mode,
    freq_write: bool,
    freq_value: uint<4>,
) -> CmdDecode {
    CmdDecode$(
        msg: msg,
        msg_valid: msg_valid,
        mode_write: mode_write,
        mode_value: mode_value,
        freq_write: freq_write,
        freq_value: freq_value,
    )
}

pub fn cmd_decode_none() -> CmdDecode {
    cmd_decode_base(MsgKind::None(), false, false, Mode::ClockTester(), false, 0)
}

pub fn cmd_decode_msg(msg: MsgKind) -> CmdDecode {
    cmd_decode_base(msg, true, false, Mode::ClockTester(), false, 0)
}

pub fn cmd_decode_set_mode(mode: Mode) -> CmdDecode {
    cmd_decode_base(MsgKind::Ok(), true, true, mode, false, 0)
}

pub fn cmd_decode_set_freq(freq: uint<4>) -> CmdDecode {
    cmd_decode_base(MsgKind::Ok(), true, true, Mode::ClockTester(), true, freq)
}

pub fn decode_bang_cmd(rx_upper: uint<8>) -> CmdDecode {
    if rx_upper == b'H' {
        cmd_decode_msg(MsgKind::Help())
    } else if rx_upper == b'S' {
        cmd_decode_msg(MsgKind::Status())
    } else if rx_upper == b'C' {
        cmd_decode_set_mode(Mode::ClockTester())
    } else if rx_upper == b'E' {
        cmd_decode_set_mode(Mode::Echo())
    } else if rx_upper == b'F' {
        cmd_decode_none()
    } else {
        cmd_decode_msg(MsgKind::ErrCmd())
    }
}

pub fn decode_cmd(
    state: CmdParseState,
    rx_ok: bool,
    rx_upper: uint<8>,
    rx_digit: DigitDecode,
) -> CmdDecode {
    if !rx_ok {
        cmd_decode_none()
    } else {
        match state {
            CmdParseState::Bang => decode_bang_cmd(rx_upper),
            CmdParseState::Freq => {
                if rx_digit.valid {
                    cmd_decode_set_freq(rx_digit.value)
                } else {
                    cmd_decode_msg(MsgKind::ErrFreq())
                }
            },
            _ => cmd_decode_none(),
        }
    }
}

pub struct SimpleCmdUartOut {
    mode: Mode,
    freq_code: uint<4>,
    cmd_state: CmdParseState,
    tx_msg_none: bool,
    tx_req: TxReq8,
    payload_rx: bool,
}

fn tx_stream_step(
    tx_state: ByteMsgStreamState<MsgKind, 8>,
    mode: Mode,
    freq_code: uint<4>,
    tx_busy: bool,
    next_msg_valid: bool,
    next_msg: MsgKind,
) -> ByteMsgStreamOut<MsgKind, 8> {
    byte_msg_stream_step_with(
        tx_state,
        MsgKind::None(),
        fn |msg| {
            match msg {
                MsgKind::None => true,
                _ => false,
            }
        },
        fn |msg, idx| { msg_byte(msg, idx, mode, freq_code) },
        tx_busy,
        next_msg_valid,
        next_msg,
    )
}

pub entity simple_cmd_uart_core(
    clk: clock,
    rst: bool,
    rx_valid: bool,
    rx_parity_error: bool,
    rx_byte: uint<8>,
    tx_busy: bool,
) -> SimpleCmdUartOut {
    let rx_decoded = inst decode_rx_byte(clk, rx_valid, rx_parity_error, rx_byte);
    let rx_ok = rx_decoded.is_some();
    let rx_decode = rx_decoded.unwrap_or(default_rx_byte_decode());

    reg(clk) cmd_state: CmdParseState reset(rst: CmdParseState::Idle()) = {
        next_cmd_state(cmd_state, rx_ok, rx_decode.byte, rx_decode.upper)
    };
    let cmd_decode = decode_cmd(cmd_state, rx_ok, rx_decode.upper, rx_decode.digit);

    reg(clk) mode: Mode reset(rst: Mode::ClockTester()) = {
        if cmd_decode.mode_write {
            cmd_decode.mode_value
        } else {
            mode
        }
    };

    reg(clk) freq_code: uint<4> reset(rst: 0) = {
        if cmd_decode.freq_write {
            cmd_decode.freq_value
        } else {
            freq_code
        }
    };

    reg(clk) tx_state: ByteMsgStreamState<MsgKind, 8>
        reset(rst: ByteMsgStreamState$(cur_msg: MsgKind::Ready(), cur_idx: 0, pending_msg: MsgKind::None()))
        = {
        tx_stream_step(tx_state, mode, freq_code, tx_busy, cmd_decode.msg_valid, cmd_decode.msg).state
    };

    let tx_stream = tx_stream_step(tx_state, mode, freq_code, tx_busy, false, MsgKind::None());
    let tx_msg_none = tx_stream.msg_none;

    let rx_is_bang = rx_ok && rx_decode.byte == b'!';
    let payload_rx = is_echo_mode(mode) && cmd_state_is_idle(cmd_state) && rx_ok && !rx_is_bang;

    SimpleCmdUartOut$(
        mode: mode,
        freq_code: freq_code,
        cmd_state: cmd_state,
        tx_msg_none: tx_msg_none,
        tx_req: tx_stream.tx_req,
        payload_rx: payload_rx,
    )
}

pub fn saleae_outputs(
    mode_is_echo: bool,
    selected_clk: bool,
    clk_100_div: bool,
    clk200_probe: bool,
    clk400_probe: bool,
    clk_50_div: bool,
    usb_rx: bool,
    usb_tx_line: bool,
    tx6_line: bool,
    tx7_line: bool,
) -> [bool; 8] {
    if mode_is_echo {
        [
            clk_100_div,
            clk200_probe,
            clk400_probe,
            clk_50_div,
            usb_rx,
            usb_tx_line,
            tx6_line,
            tx7_line,
        ]
    } else {
        [selected_clk, false, false, false, false, false, false, false]
    }
}
