{
  "version": "0.1.0",
  "configurations": [
    {
      "name": "Run All JITX Designs in Project",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "module": "jitx",
      "args": [
        "build-all",
        "--port",
        "${command:jitx.get-websocket-port}",
        "--generate-config"
      ],
      "justMyCode": false,
      "python": "${workspaceFolder}/.venv/bin/python",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run src.main.SharpSc62015InterposerDesign",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "module": "jitx",
      "args": [
        "build",
        "src.main.SharpSc62015InterposerDesign",
        "--port",
        "${command:jitx.get-websocket-port}"
      ],
      "justMyCode": false,
      "python": "${workspaceFolder}/.venv/bin/python",
      "cwd": "${workspaceFolder}"
    }
  ]
}
