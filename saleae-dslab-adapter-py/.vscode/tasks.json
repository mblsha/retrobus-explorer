{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run saleae_dslab_adapter.main.SaleaeDSLabAdapter",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "jitx",
        "build",
        "saleae_dslab_adapter.main.SaleaeDSLabAdapter",
        "--port",
        "${command:jitx.get-websocket-port}"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build"
      },
      "detail": "JITX Build task"
    },
    {
      "label": "Run All JITX Designs in Project",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "jitx",
        "build-all",
        "--port",
        "${command:jitx.get-websocket-port}"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build"
      },
      "detail": "JITX Build task"
    }
  ]
}
